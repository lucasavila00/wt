---
source: crates/wt-cli/src/ssh.rs
expression: "normalize_home(&managed, temp.path())"
---
# Generated by wt sync. Do not edit.

Host local.same-host
  HostName 192.0.2.2
  User wt
  Port 22
  HostKeyAlias local.same-host
  UserKnownHostsFile "[HOME]/.ssh/wt/known_hosts"
  StrictHostKeyChecking yes
  SetEnv TERM=xterm-256color

Host local.same
  HostName 192.0.2.2
  User wt
  Port 22
  HostKeyAlias local.same-host
  UserKnownHostsFile "[HOME]/.ssh/wt/known_hosts"
  StrictHostKeyChecking yes
  SetEnv TERM=xterm-256color
  ForwardAgent yes
  RequestTTY force
  RemoteCommand BYOBU_ALT_TITLE='local.same - repo' /usr/local/bin/wt-app-shell

Host local.same-vs
  HostName wt-app
  User vscode
  Port 2222
  HostKeyAlias local.same-vs
  UserKnownHostsFile "[HOME]/.ssh/wt/known_hosts"
  StrictHostKeyChecking yes
  ForwardAgent yes
  SetEnv TERM=xterm-256color
  ProxyCommand ssh -F "[HOME]/.ssh/config" local.same-host /usr/local/bin/wt-app-proxy

Host lab.same-host
  HostName 192.0.2.2
  User wt
  Port 22
  HostKeyAlias lab.same-host
  UserKnownHostsFile "[HOME]/.ssh/wt/known_hosts"
  StrictHostKeyChecking yes
  SetEnv TERM=xterm-256color
  ProxyJump wt-server

Host lab.same
  HostName 192.0.2.2
  User wt
  Port 22
  HostKeyAlias lab.same-host
  UserKnownHostsFile "[HOME]/.ssh/wt/known_hosts"
  StrictHostKeyChecking yes
  SetEnv TERM=xterm-256color
  ProxyJump wt-server
  ForwardAgent yes
  RequestTTY force
  RemoteCommand BYOBU_ALT_TITLE='lab.same - repo' /usr/local/bin/wt-app-shell

Host lab.same-vs
  HostName wt-app
  User vscode
  Port 2222
  HostKeyAlias lab.same-vs
  UserKnownHostsFile "[HOME]/.ssh/wt/known_hosts"
  StrictHostKeyChecking yes
  ForwardAgent yes
  SetEnv TERM=xterm-256color
  ProxyCommand ssh -F "[HOME]/.ssh/config" lab.same-host /usr/local/bin/wt-app-proxy
