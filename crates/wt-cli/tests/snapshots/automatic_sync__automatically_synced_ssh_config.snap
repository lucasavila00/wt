---
source: crates/wt-cli/tests/automatic_sync.rs
expression: "managed.replace(&temp.path().display().to_string(), \"[HOME]\")"
---
# Generated by wt sync. Do not edit.

Host local.repo-feature-host
  HostName 192.0.2.2
  User wt
  Port 22
  HostKeyAlias local.repo-feature-host
  UserKnownHostsFile "[HOME]/.ssh/wt/known_hosts"
  StrictHostKeyChecking yes
  SetEnv TERM=xterm-256color

Host local.repo-feature
  HostName 192.0.2.2
  User wt
  Port 22
  HostKeyAlias local.repo-feature-host
  UserKnownHostsFile "[HOME]/.ssh/wt/known_hosts"
  StrictHostKeyChecking yes
  SetEnv TERM=xterm-256color
  RequestTTY force
  RemoteCommand /usr/local/bin/wt-app-shell

Host local.repo-feature-vs local.repo-feature-vc
  HostName wt-app
  User vscode
  Port 2222
  HostKeyAlias local.repo-feature-vs
  UserKnownHostsFile "[HOME]/.ssh/wt/known_hosts"
  StrictHostKeyChecking yes
  SetEnv TERM=xterm-256color
  ProxyCommand ssh -F "[HOME]/.ssh/config" local.repo-feature-host /usr/local/bin/wt-app-proxy

Host repo-feature-host
  HostName 192.0.2.2
  User wt
  Port 22
  HostKeyAlias local.repo-feature-host
  UserKnownHostsFile "[HOME]/.ssh/wt/known_hosts"
  StrictHostKeyChecking yes
  SetEnv TERM=xterm-256color

Host repo-feature
  HostName 192.0.2.2
  User wt
  Port 22
  HostKeyAlias local.repo-feature-host
  UserKnownHostsFile "[HOME]/.ssh/wt/known_hosts"
  StrictHostKeyChecking yes
  SetEnv TERM=xterm-256color
  RequestTTY force
  RemoteCommand /usr/local/bin/wt-app-shell

Host repo-feature-vs repo-feature-vc
  HostName wt-app
  User vscode
  Port 2222
  HostKeyAlias local.repo-feature-vs
  UserKnownHostsFile "[HOME]/.ssh/wt/known_hosts"
  StrictHostKeyChecking yes
  SetEnv TERM=xterm-256color
  ProxyCommand ssh -F "[HOME]/.ssh/config" local.repo-feature-host /usr/local/bin/wt-app-proxy
