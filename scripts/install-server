#!/usr/bin/env bash
set -euo pipefail

report_failure() {
    status=$?
    if (( status != 0 )); then
        printf '\nERROR: wt server installation stopped before completion (exit status %d).\n' "$status" >&2
    fi
}
trap report_failure EXIT

root=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)

if [[ $# -ne 2 || $1 != --config ]]; then
    echo "usage: scripts/install-server --config PATH" >&2
    exit 2
fi
config=$2

if [[ $EUID -eq 0 ]]; then
    echo "run this script as the server user, not with sudo" >&2
    exit 1
fi
if [[ ! -t 0 ]]; then
    echo "run this script in an interactive terminal; sudo authentication is required" >&2
    exit 1
fi
if [[ ! -f $config ]]; then
    echo "config file not found: $config" >&2
    exit 1
fi
config=$(realpath "$config")

# shellcheck source=/dev/null
source /etc/os-release
if [[ ${ID:-} != ubuntu || ${VERSION_ID:-} != 24.04 ]]; then
    echo "Ubuntu 24.04 is required" >&2
    exit 1
fi
if [[ $(dpkg --print-architecture) != amd64 ]]; then
    echo "amd64 is required" >&2
    exit 1
fi
if ! command -v cargo >/dev/null; then
    echo "Rust stable via rustup is required" >&2
    exit 1
fi

sudo apt update
packages=( \
    build-essential \
    pkg-config \
    git \
    curl \
    cpu-checker \
    qemu-system-x86 \
    qemu-utils \
    libvirt-daemon-system \
    libvirt-clients \
    virtinst \
    cloud-image-utils \
    libguestfs-tools \
    ovmf \
    libvirt-dev \
    acl \
    openssh-client \
    openssh-server
)
if ! command -v docker >/dev/null; then
    packages+=(docker.io)
fi
sudo apt install -y "${packages[@]}"

cd "$root"
cargo build --release -p wt-server-setup
target/release/wt-server-setup validate --config "$config"

sudo usermod -aG docker,libvirt,kvm "$USER"
groups=" $(id -nG) "
if [[ $groups != *" docker "* || $groups != *" libvirt "* || $groups != *" kvm "* ]]; then
    echo "docker/libvirt/kvm group membership was added but is not active" >&2
    echo "log out, log back in, then rerun this command" >&2
    exit 1
fi

target/release/wt-server-setup install --config "$config"
