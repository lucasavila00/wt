#!/usr/bin/env bash
set -euo pipefail

report_failure() {
    status=$?
    if (( status != 0 )); then
        printf '\nERROR: image preparation stopped before completion (exit status %d).\n' "$status" >&2
    fi
}
trap report_failure EXIT

root=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)

if [[ $# -ne 2 || $1 != --config ]]; then
    echo "usage: scripts/prepare-image --config PATH" >&2
    exit 2
fi
if [[ ! -t 0 ]]; then
    echo "run this script in an interactive terminal; sudo authentication is required" >&2
    exit 1
fi
if [[ ! -f $2 ]]; then
    echo "config file not found: $2" >&2
    exit 1
fi
config=$(realpath "$2")

cd "$root"
cargo run --release -p wt-server-setup -- image rebuild --config "$config"
