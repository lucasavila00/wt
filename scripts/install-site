#!/usr/bin/env bash
set -euo pipefail

root=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)

if [[ $# -ne 2 || $1 != --config ]]; then
    echo "usage: scripts/install-site --config PATH" >&2
    exit 2
fi
config=$2

if [[ $EUID -eq 0 ]]; then
    echo "run this script as the site user, not with sudo" >&2
    exit 1
fi
if [[ ! -t 0 ]]; then
    echo "run this script in an interactive terminal; sudo authentication is required" >&2
    exit 1
fi
if [[ ! -f $config ]]; then
    echo "config file not found: $config" >&2
    exit 1
fi
config=$(realpath "$config")

# shellcheck source=/dev/null
source /etc/os-release
if [[ ${ID:-} != ubuntu || ${VERSION_ID:-} != 24.04 ]]; then
    echo "Ubuntu 24.04 is required" >&2
    exit 1
fi
if [[ $(dpkg --print-architecture) != amd64 ]]; then
    echo "amd64 is required" >&2
    exit 1
fi
if ! command -v cargo >/dev/null; then
    echo "Rust stable via rustup is required" >&2
    exit 1
fi

sudo apt update
sudo apt install -y \
    build-essential \
    pkg-config \
    git \
    curl \
    cpu-checker \
    qemu-system-x86 \
    qemu-utils \
    libvirt-daemon-system \
    libvirt-clients \
    virtinst \
    cloud-image-utils \
    libguestfs-tools \
    ovmf \
    libvirt-dev \
    openssh-server

cd "$root"
cargo build --release -p wt-local-setup
target/release/wt-local-setup validate --config "$config"

sudo usermod -aG libvirt,kvm "$USER"
groups=" $(id -nG) "
if [[ $groups != *" libvirt "* || $groups != *" kvm "* ]]; then
    echo "libvirt/kvm group membership was added but is not active" >&2
    echo "log out, log back in, then rerun this command" >&2
    exit 1
fi

target/release/wt-local-setup install --config "$config"
